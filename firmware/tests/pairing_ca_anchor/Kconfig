mainmenu "pairing_ca_anchor ztest"

config CANTIL_MAX_KEY_SLOTS
	int "Maximum number of key slots"
	default 8
	range 1 64

config CANTIL_CRL_VALIDITY_SEC
	int "CRL nextUpdate window (seconds)"
	default 86400

config CANTIL_REVOKE_REQUIRE_NOW_UNIX
	bool "Require host-supplied revocation timestamp"
	default n

# Pairing method symbols — flat booleans (no choice wrapper in test context).
config PAIRING_PROMISCUOUS
	bool "Method 0 — Promiscuous"
	default n

config PAIRING_TOFU
	bool "Method 1 — Silent TOFU"
	default n

config PAIRING_TAP_CONFIRM
	bool "Method 2 — Tap-confirmed bond"
	default n

config PAIRING_PASSKEY
	bool "Method 3 — Passkey + tap-confirmed bond"
	default n

config PAIRING_CA_ANCHOR
	bool "Method 4 — CA-anchored client cert"
	default n

config CANTIL_CA_ANCHOR_SLOT
	int "CA slot to use as trust anchor for Method 4"
	default 0
	depends on PAIRING_CA_ANCHOR

source "Kconfig.zephyr"
